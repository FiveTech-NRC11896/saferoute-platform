@startuml
skinparam monochrome false

package "trip.domain.model.entity" {
  class Trip {
    - id: UUID
    - organizationId: UUID
    - routeId: UUID
    - driverId: UUID
    - tripState: String
    - startTime: LocalDateTime
    - endTime: LocalDateTime
    + start(): void
    + complete(): void
    + recordBoarding(childId: UUID, state: String): void
    + reportIncident(description: String): void
    + getAttendanceSummary(): List<Attendance>
    + getIncidentLog(): List<Incident>
    + isInProgress(): boolean
    + getId(): UUID
  }

  class Attendance {
    - id: UUID
    - tripId: UUID
    - childId: UUID
    - boardingState: String
    - boardedAt: LocalDateTime
    + updateBoardingState(state: String): void
    + isBoarded(): boolean
    + getBoardingTime(): LocalDateTime
    + getId(): UUID
  }

  class Incident {
    - id: UUID
    - tripId: UUID
    - description: String
    - reportedAt: LocalDateTime
    + report(): void
    + getDescription(): String
    + getReportedAt(): LocalDateTime
    + getId(): UUID
  }
}

package "trip.interfaces.rest.resources" {
  class StartTripRequest {
    + routeId: String
    + driverId: String
    + organizationId: String
  }

  class TripResponse {
    + id: String
    + organizationId: String
    + routeId: String
    + driverId: String
    + tripState: String
    + startTime: String
    + endTime: String
  }

  class UpdateBoardingRequest {
    + childId: String
    + boardingState: String
  }

  class AttendanceResponse {
    + id: String
    + tripId: String
    + childId: String
    + boardingState: String
    + boardedAt: String
  }

  class ReportIncidentRequest {
    + description: String
  }

  class IncidentResponse {
    + id: String
    + tripId: String
    + description: String
    + reportedAt: String
  }
}

package "trip.interfaces.rest.assemblers" {
  class TripAssembler {
    + toEntityFromRequest(request: StartTripRequest): Trip
    + toResourceFromEntity(trip: Trip): TripResponse
  }

  class AttendanceAssembler {
    + toEntityFromRequest(request: UpdateBoardingRequest): Attendance
    + toResourceFromEntity(attendance: Attendance): AttendanceResponse
  }

  class IncidentAssembler {
    + toEntityFromRequest(request: ReportIncidentRequest): Incident
    + toResourceFromEntity(incident: Incident): IncidentResponse
  }
}

package "trip.interfaces.rest.controllers" {
  class TripController {
    + startTrip(request: StartTripRequest): TripResponse
    + getTripById(id: String): TripResponse
    + getTripsByRoute(routeId: String): List<TripResponse>
    + completeTrip(id: String): TripResponse
  }

  class AttendanceController {
    + updateBoardingStatus(tripId: String, request: UpdateBoardingRequest): AttendanceResponse
    + getAttendanceByTrip(tripId: String): List<AttendanceResponse>
  }

  class IncidentController {
    + reportIncident(tripId: String, request: ReportIncidentRequest): IncidentResponse
    + getIncidentsByTrip(tripId: String): List<IncidentResponse>
  }
}

StartTripRequest --> TripAssembler : uses
TripAssembler --> Trip : creates
TripAssembler --> TripResponse : creates
TripController --> TripAssembler : uses
TripController --> StartTripRequest : uses
TripController --> TripResponse : returns
UpdateBoardingRequest --> AttendanceAssembler : uses
AttendanceAssembler --> Attendance : creates
AttendanceAssembler --> AttendanceResponse : creates
AttendanceController --> AttendanceAssembler : uses
AttendanceController --> AttendanceResponse : returns
ReportIncidentRequest --> IncidentAssembler : uses
IncidentAssembler --> Incident : creates
IncidentAssembler --> IncidentResponse : creates
IncidentController --> IncidentAssembler : uses
IncidentController --> IncidentResponse : returns
Trip "1" *--> "0..*" Attendance : contains
Trip "1" *--> "0..*" Incident : contains

@enduml

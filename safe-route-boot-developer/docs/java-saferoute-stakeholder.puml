@startuml
skinparam monochrome false

package "stakeholder.domain.model.entity" {
  class Parent {
    - id: UUID
    - organizationId: UUID
    - userId: UUID
    - firstName: String
    - lastName: String
    - email: String
    - phoneNumber: String
    + addChild(child: Child): void
    + removeChild(childId: UUID): void
    + getChildren(): List<Child>
    + getFullName(): String
    + getId(): UUID
    + getOrganizationId(): UUID
  }

  class Driver {
    - id: UUID
    - organizationId: UUID
    - userId: UUID
    - firstName: String
    - lastName: String
    - email: String
    - phoneNumber: String
    - licenseNumber: String
    + isAvailable(): boolean
    + getFullName(): String
    + getLicenseNumber(): String
    + getId(): UUID
    + getOrganizationId(): UUID
  }

  class Child {
    - id: UUID
    - parentId: UUID
    - firstName: String
    - lastName: String
    - age: int
    - enrollmentState: String
    + enroll(): void
    + unenroll(): void
    + isEnrolled(): boolean
    + getFullName(): String
    + getId(): UUID
  }

  class StudentGroup {
    - id: UUID
    - organizationId: UUID
    - name: String
    - childIds: List<UUID>
    - isFinalized: boolean
    + addChild(childId: UUID): void
    + removeChild(childId: UUID): void
    + finalize(): void
    + getChildCount(): int
    + isFinalized(): boolean
    + getId(): UUID
  }
}

package "stakeholder.interfaces.rest.resources" {
  class CreateParentRequest {
    + firstName: String
    + lastName: String
    + email: String
    + phoneNumber: String
    + organizationId: String
    + userId: String
  }

  class ParentResponse {
    + id: String
    + fullName: String
    + email: String
    + phoneNumber: String
    + organizationId: String
  }

  class CreateDriverRequest {
    + firstName: String
    + lastName: String
    + email: String
    + phoneNumber: String
    + licenseNumber: String
    + organizationId: String
    + userId: String
  }

  class DriverResponse {
    + id: String
    + fullName: String
    + email: String
    + phoneNumber: String
    + licenseNumber: String
    + organizationId: String
  }

  class CreateChildRequest {
    + firstName: String
    + lastName: String
    + age: int
    + parentId: String
  }

  class ChildResponse {
    + id: String
    + fullName: String
    + age: int
    + enrollmentState: String
    + parentId: String
  }

  class CreateStudentGroupRequest {
    + name: String
    + organizationId: String
  }

  class StudentGroupResponse {
    + id: String
    + name: String
    + organizationId: String
    + childIds: List<String>
    + isFinalized: boolean
  }
}

package "stakeholder.interfaces.rest.assemblers" {
  class ParentAssembler {
    + toEntityFromRequest(request: CreateParentRequest): Parent
    + toResourceFromEntity(parent: Parent): ParentResponse
  }

  class DriverAssembler {
    + toEntityFromRequest(request: CreateDriverRequest): Driver
    + toResourceFromEntity(driver: Driver): DriverResponse
  }

  class ChildAssembler {
    + toEntityFromRequest(request: CreateChildRequest): Child
    + toResourceFromEntity(child: Child): ChildResponse
  }

  class StudentGroupAssembler {
    + toEntityFromRequest(request: CreateStudentGroupRequest): StudentGroup
    + toResourceFromEntity(group: StudentGroup): StudentGroupResponse
  }
}

package "stakeholder.interfaces.rest.controllers" {
  class ParentController {
    + createParent(request: CreateParentRequest): ParentResponse
    + getParentById(id: String): ParentResponse
    + getParentsByOrganization(organizationId: String): List<ParentResponse>
    + deleteParent(id: String): void
  }

  class DriverController {
    + createDriver(request: CreateDriverRequest): DriverResponse
    + getDriverById(id: String): DriverResponse
    + getDriversByOrganization(organizationId: String): List<DriverResponse>
    + deleteDriver(id: String): void
  }

  class ChildController {
    + createChild(request: CreateChildRequest): ChildResponse
    + getChildById(id: String): ChildResponse
    + getChildrenByParent(parentId: String): List<ChildResponse>
    + deleteChild(id: String): void
  }

  class StudentGroupController {
    + createStudentGroup(request: CreateStudentGroupRequest): StudentGroupResponse
    + getStudentGroupById(id: String): StudentGroupResponse
    + addChildToGroup(groupId: String, childId: String): StudentGroupResponse
    + finalizeGroup(id: String): StudentGroupResponse
  }
}

CreateParentRequest --> ParentAssembler : uses
ParentAssembler --> Parent : creates
ParentAssembler --> ParentResponse : creates
ParentController --> ParentAssembler : uses
ParentController --> CreateParentRequest : uses
ParentController --> ParentResponse : returns
CreateDriverRequest --> DriverAssembler : uses
DriverAssembler --> Driver : creates
DriverAssembler --> DriverResponse : creates
DriverController --> DriverAssembler : uses
DriverController --> CreateDriverRequest : uses
DriverController --> DriverResponse : returns
CreateChildRequest --> ChildAssembler : uses
ChildAssembler --> Child : creates
ChildAssembler --> ChildResponse : creates
ChildController --> ChildAssembler : uses
ChildController --> CreateChildRequest : uses
ChildController --> ChildResponse : returns
CreateStudentGroupRequest --> StudentGroupAssembler : uses
StudentGroupAssembler --> StudentGroup : creates
StudentGroupAssembler --> StudentGroupResponse : creates
StudentGroupController --> StudentGroupAssembler : uses
StudentGroupController --> CreateStudentGroupRequest : uses
StudentGroupController --> StudentGroupResponse : returns
Parent "1" *--> "1..*" Child : contains

@enduml

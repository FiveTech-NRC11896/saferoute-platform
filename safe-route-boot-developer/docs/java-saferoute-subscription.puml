@startuml
skinparam monochrome false

package "subscription.domain.model.entity" {
  class Subscription {
    - id: UUID
    - organizationId: UUID
    - planId: UUID
    - state: String
    - startDate: LocalDateTime
    - endDate: LocalDateTime
    + activate(): void
    + upgrade(planId: UUID): void
    + cancel(): void
    + isActive(): boolean
    + getPlanId(): UUID
    + getRemainingDays(): int
    + getId(): UUID
  }

  class Plan {
    - id: UUID
    - planTier: String
    - maxRoutes: int
    - maxDrivers: int
    - price: double
    + getPlanName(): String
    + getRouteLimit(): int
    + getDriverLimit(): int
    + isWithinRouteQuota(current: int): boolean
    + isWithinDriverQuota(current: int): boolean
    + getId(): UUID
  }
}

package "subscription.interfaces.rest.resources" {
  class CreateSubscriptionRequest {
    + organizationId: String
    + planId: String
  }

  class SubscriptionResponse {
    + id: String
    + organizationId: String
    + planId: String
    + state: String
    + startDate: String
    + endDate: String
  }

  class UpgradeSubscriptionRequest {
    + planId: String
  }

  class CreatePlanRequest {
    + planTier: String
    + maxRoutes: int
    + maxDrivers: int
    + price: double
  }

  class PlanResponse {
    + id: String
    + planTier: String
    + maxRoutes: int
    + maxDrivers: int
    + price: double
  }
}

package "subscription.interfaces.rest.assemblers" {
  class SubscriptionAssembler {
    + toEntityFromRequest(request: CreateSubscriptionRequest): Subscription
    + toResourceFromEntity(subscription: Subscription): SubscriptionResponse
  }

  class PlanAssembler {
    + toEntityFromRequest(request: CreatePlanRequest): Plan
    + toResourceFromEntity(plan: Plan): PlanResponse
  }
}

package "subscription.interfaces.rest.controllers" {
  class SubscriptionController {
    + createSubscription(request: CreateSubscriptionRequest): SubscriptionResponse
    + getSubscriptionByOrganizationId(organizationId: String): SubscriptionResponse
    + upgradeSubscription(id: String, request: UpgradeSubscriptionRequest): SubscriptionResponse
    + cancelSubscription(id: String): void
  }

  class PlanController {
    + createPlan(request: CreatePlanRequest): PlanResponse
    + getAllPlans(): List<PlanResponse>
    + getPlanById(id: String): PlanResponse
  }
}

CreateSubscriptionRequest --> SubscriptionAssembler : uses
SubscriptionAssembler --> Subscription : creates
SubscriptionAssembler --> SubscriptionResponse : creates
SubscriptionController --> SubscriptionAssembler : uses
SubscriptionController --> CreateSubscriptionRequest : uses
SubscriptionController --> UpgradeSubscriptionRequest : uses
SubscriptionController --> SubscriptionResponse : returns
CreatePlanRequest --> PlanAssembler : uses
PlanAssembler --> Plan : creates
PlanAssembler --> PlanResponse : creates
PlanController --> PlanAssembler : uses
PlanController --> CreatePlanRequest : uses
PlanController --> PlanResponse : returns
Subscription ..> Plan : references by id

@enduml
